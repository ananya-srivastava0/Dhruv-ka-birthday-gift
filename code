</div>

<div class="main" id="main">

    <div class="title">
        HAPPY BIRTHDAY<br>DHRUV
    </div>

    <div class="subtitle">
        CERTIFIED AESTHETIC MERCHANT
    </div>

    <div class="cards">

        <div class="card">
            Professional girl attractor detected.
        </div>

